// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`createDefineSampleWindow > snapshot of params panel 1`] = `
"
      
      <input type="radio" value="step" id="radio-step" name="sample-mode-Id-TEST0001">
      <label for="radio-step">Sampling with step:</label>
      <input type="number" value="25" min="0.001" step="any">
      <input type="radio" value="xvals" id="radio-xvals" name="sample-mode-Id-TEST0001" disabled="">
      <label for="radio-xvals">Using x values of series (select 2 series)</label>
      <label>Kind:</label>
      <select>
        <!---->
          <option value="nearest">nearest</option>
        <!----><!---->
          <option value="zero">zero</option>
        <!----><!---->
          <option value="linear">linear</option>
        <!----><!---->
          <option value="quadratic">quadratic</option>
        <!----><!---->
          <option value="cubic">cubic</option>
        <!---->
      </select>
      <input type="checkbox" id="sample-int">
      <label for="sample-int">Integration</label>
    "
`;
