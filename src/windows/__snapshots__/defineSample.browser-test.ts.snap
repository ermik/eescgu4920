// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`createDefineSampleWindow > snapshot of params panel 1`] = `"<input type="radio" name="sample-mode-Id-TEST0001" value="step" id="radio-step"><label for="radio-step">Sampling with step:</label><input type="number" min="0.001" step="any"><input type="radio" name="sample-mode-Id-TEST0001" value="xvals" id="radio-xvals" disabled=""><label for="radio-xvals">Using x values of series (select 2 series)</label><label>Kind:</label><select><option value="nearest">nearest</option><option value="zero">zero</option><option value="linear">linear</option><option value="quadratic">quadratic</option><option value="cubic">cubic</option></select><input type="checkbox" id="sample-int"><label for="sample-int">Integration</label>"`;
